{
  "mcpServers": {
    "fable": {
      "command": "node",
      "args": ["dist/server.bundled.mjs"],
      "env": {
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
        "FABLE_MODEL": "${FABLE_MODEL}",
        "FABLE_EFFORT": "${FABLE_EFFORT}",
        "FABLE_MAX_TURNS": "${FABLE_MAX_TURNS}",
        "FABLE_TIMEOUT_MS": "${FABLE_TIMEOUT_MS}",
        "FABLE_CLAUDE_BIN": "${FABLE_CLAUDE_BIN}"
      }
    }
  }
}
